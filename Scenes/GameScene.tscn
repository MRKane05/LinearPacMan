[sub_resource type="Shader" id=12]
code = "shader_type canvas_item;

uniform sampler2D mask_texture : hint_white;
uniform float scroll_speed = 1.0;
uniform float scroll_direction = 1.0;
uniform int frame_columns = 5;
uniform int frame_rows = 5;

void fragment() {
    vec4 sprite_color = texture(TEXTURE, UV);
    
    // Remap UV from frame-space back to 0-1 space
    float frame_width = 1.0 / float(frame_columns);
    float frame_height = 1.0 / float(frame_rows);
    
    vec2 normalized_uv = vec2(
        mod(UV.x, frame_width) / frame_width,
        mod(UV.y, frame_height) / frame_height
    );
    
    // Apply scroll to the normalized UV
    vec2 wave_uv = normalized_uv + vec2(TIME * scroll_speed * scroll_direction, 0.0);
    vec4 mask_color = texture(mask_texture, wave_uv);
    
    sprite_color.a *= mask_color.a;
    COLOR = sprite_color;
}"

